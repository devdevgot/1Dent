modules = ["nodejs-24", "python-3.11", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [userenv]

  [userenv.shared]
VITE_YANDEX_MAPS_API_KEY = "3ca6647f-f79e-47bf-8537-882a2aeb8212"
VITE_YANDEX_GEOCODER_KEY = "9b325167-ed8c-45dc-9bd2-01d4afb2c8ab"
YANDEX_GEOCODER_KEY = "9b325167-ed8c-45dc-9bd2-01d4afb2c8ab"
PLATFORM_SUPERADMIN_TG_ID = "1337923744"

[userenv.development]
TMA_DEV_BYPASS_TG_ID = "999999999"

  [nix]
  channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 8085
externalPort = 6000

[[ports]]
localPort = 23816
externalPort = 80

[[ports]]
localPort = 23817
externalPort = 5000

[[ports]]
localPort = 23818
externalPort = 3000

[[ports]]
localPort = 23819
externalPort = 3002

[[ports]]
localPort = 23820
externalPort = 3003
  