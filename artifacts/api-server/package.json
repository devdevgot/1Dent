    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
