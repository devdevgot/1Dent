{
  "name": "@1dent/landing",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/api/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "start": "bun src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && oxlint packages/web --deny-warnings --no-error-on-unmatched-pattern",
    "preview": "bun run build && vite preview",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@runablehq/website-runtime": "^0.10.0",
    "@tanstack/react-query": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "drizzle-orm": "catalog:",
    "framer-motion": "catalog:",
    "hono": "^4.12.10",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "tailwind-merge": "catalog:",
    "wouter": "^3.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.0",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "catalog:"
  },
  "description": "1Dent landing page"
}
